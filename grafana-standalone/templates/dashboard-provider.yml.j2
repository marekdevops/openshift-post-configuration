# Grafana dashboard provisioning provider
# Wygenerowano przez Ansible — nie edytuj recznie
apiVersion: 1

providers:
  - name: OpenShift Dashboards
    orgId: 1
    folder: OpenShift
    type: file
    disableDeletion: false
    updateIntervalSeconds: 30
    allowUiUpdates: true
    options:
      path: /var/lib/grafana/dashboards
