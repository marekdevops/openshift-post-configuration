# Grafana provisioning datasource — OCP {{ ds.cluster_type }} - {{ ds.name }}
# Wygenerowano przez Ansible — nie edytuj recznie
apiVersion: 1

datasources:
  - name: "OCP-{{ ds.cluster_type }} - {{ ds.name }}"
    type: prometheus
    uid: "ocp-{{ ds.cluster_type | lower }}-{{ ds.name | lower | regex_replace('[^a-z0-9]', '-') }}"
    access: proxy
    url: "{{ ds.thanos_url }}"
    isDefault: false
    editable: true
    jsonData:
      httpMethod: POST
      httpHeaderName1: "Authorization"
      timeInterval: "30s"
      tlsSkipVerify: true
    secureJsonData:
      httpHeaderValue1: "Bearer {{ ds.bearer_token }}"
