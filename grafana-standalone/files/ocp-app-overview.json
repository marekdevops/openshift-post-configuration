{
  "title": "OCP App Clusters Overview",
  "uid": "ocp-app-overview",
  "description": "OpenShift — klastry aplikacyjne. Operatory, wezly, alerty, pody, storage.",
  "tags": ["openshift", "app", "cluster"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "graphTooltip": 1,
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "weekStart": "",
  "editable": true,
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Klaster APP",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "regex": "OCP-APP - .*",
        "refresh": 1,
        "type": "datasource",
        "description": "Wybierz klaster aplikacyjny"
      }
    ]
  },
  "annotations": { "list": [] },
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 1, "title": "Cluster Health", "type": "row" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "mappings": [], "unit": "none", "noValue": "N/A" }, "overrides": [] }, "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 }, "id": 2, "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "name" }, "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "cluster_version{type=\"completed\"}", "legendFormat": "OCP {{version}}", "instant": true, "refId": "A" }], "title": "Wersja OCP", "type": "stat" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "none" }, "overrides": [] }, "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 }, "id": 3, "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }, "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "count(kube_node_info)", "legendFormat": "Węzły", "instant": true, "refId": "A" }], "title": "Węzły klastra", "type": "stat" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "none" }, "overrides": [] }, "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 }, "id": 4, "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }, "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "count(kube_pod_status_phase{phase=\"Running\"})", "legendFormat": "Running", "instant": true, "refId": "A" }], "title": "Pody Running", "type": "stat" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }, "unit": "none", "noValue": "0" }, "overrides": [] }, "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 }, "id": 5, "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }, "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "count(kube_pod_status_phase{phase!~\"Running|Succeeded\"}) or vector(0)", "legendFormat": "Problem", "instant": true, "refId": "A" }], "title": "Pody z problemem", "type": "stat" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "none", "noValue": "0" }, "overrides": [] }, "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 }, "id": 6, "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }, "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "count(cluster_operator_conditions{condition=\"Degraded\",reason!=\"AsExpected\"}) or vector(0)", "legendFormat": "Degraded", "instant": true, "refId": "A" }], "title": "Operatory Degraded", "type": "stat" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }] }, "unit": "none", "noValue": "0" }, "overrides": [] }, "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 }, "id": 7, "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }, "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "count(cluster_operator_conditions{condition=\"Progressing\",reason!=\"AsExpected\"}) or vector(0)", "legendFormat": "Progressing", "instant": true, "refId": "A" }], "title": "Operatory Progressing", "type": "stat" },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "id": 10, "title": "Utilizacja Klastra", "type": "row" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity", "showPoints": "never" }, "unit": "percent", "min": 0, "max": 100 }, "overrides": [] }, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }, "id": 11, "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } }, "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "100 - (avg by (node) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{node}}", "refId": "A" }], "title": "CPU Usage per Node (%)", "type": "timeseries" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity", "showPoints": "never" }, "unit": "percent", "min": 0, "max": 100 }, "overrides": [] }, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }, "id": 12, "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } }, "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))", "legendFormat": "{{instance}}", "refId": "A" }], "title": "Memory Usage per Node (%)", "type": "timeseries" },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "id": 20, "title": "Cluster Operators", "type": "row" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "custom": { "align": "left", "displayMode": "auto", "filterable": true, "minWidth": 120 } }, "overrides": [ { "matcher": { "id": "byName", "options": "Available" }, "properties": [ { "id": "custom.width", "value": 100 }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "mappings", "value": [ { "type": "value", "options": { "1": { "text": "OK", "color": "green", "index": 0 } } }, { "type": "value", "options": { "0": { "text": "FAIL", "color": "red", "index": 1 } } } ] } ] }, { "matcher": { "id": "byName", "options": "Degraded" }, "properties": [ { "id": "custom.width", "value": 100 }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "mappings", "value": [ { "type": "value", "options": { "0": { "text": "OK", "color": "green", "index": 0 } } }, { "type": "value", "options": { "1": { "text": "DEGRADED", "color": "red", "index": 1 } } } ] } ] }, { "matcher": { "id": "byName", "options": "Progressing" }, "properties": [ { "id": "custom.width", "value": 110 }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "mappings", "value": [ { "type": "value", "options": { "0": { "text": "Idle", "color": "green", "index": 0 } } }, { "type": "value", "options": { "1": { "text": "Updating", "color": "yellow", "index": 1 } } } ] } ] }, { "matcher": { "id": "byName", "options": "name" }, "properties": [ { "id": "displayName", "value": "Operator" }, { "id": "custom.width", "value": 240 } ] } ] }, "gridPos": { "h": 12, "w": 24, "x": 0, "y": 15 }, "id": 21, "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "displayName": "Operator", "desc": false }] }, "transformations": [ { "id": "filterFieldsByName", "options": { "include": { "names": ["name", "Value #A", "Value #B", "Value #C"] } } }, { "id": "organize", "options": { "renameByName": { "Value #A": "Available", "Value #B": "Degraded", "Value #C": "Progressing" } } } ], "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "cluster_operator_conditions{condition=\"Available\"}", "legendFormat": "Available", "instant": true, "refId": "A", "format": "table" }, { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "cluster_operator_conditions{condition=\"Degraded\"}", "legendFormat": "Degraded", "instant": true, "refId": "B", "format": "table" }, { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "cluster_operator_conditions{condition=\"Progressing\"}", "legendFormat": "Progressing", "instant": true, "refId": "C", "format": "table" } ], "title": "Stan Cluster Operators", "type": "table" },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }, "id": 30, "title": "etcd Health", "type": "row" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }, "mappings": [ { "type": "value", "options": { "0": { "text": "NO LEADER", "color": "red" } } }, { "type": "value", "options": { "1": { "text": "HAS LEADER", "color": "green" } } } ], "unit": "none" } }, "gridPos": { "h": 4, "w": 4, "x": 0, "y": 28 }, "id": 31, "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }, "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "min(etcd_server_has_leader)", "legendFormat": "Leader", "instant": true, "refId": "A" }], "title": "etcd Leader", "type": "stat" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 5 }] }, "unit": "none" } }, "gridPos": { "h": 4, "w": 4, "x": 0, "y": 32 }, "id": 32, "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }, "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "count(etcd_server_has_leader)", "legendFormat": "Members", "instant": true, "refId": "A" }], "title": "etcd Members", "type": "stat" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity", "showPoints": "never" }, "unit": "s" } }, "gridPos": { "h": 8, "w": 10, "x": 4, "y": 28 }, "id": 33, "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } }, "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, rate(etcd_disk_wal_fsync_duration_seconds_bucket[5m]))", "legendFormat": "WAL P99 {{pod}}", "refId": "A" }], "title": "etcd WAL fsync latency P99", "type": "timeseries" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity", "showPoints": "never" }, "unit": "bytes" } }, "gridPos": { "h": 8, "w": 10, "x": 14, "y": 28 }, "id": 34, "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } }, "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "etcd_mvcc_db_total_size_in_bytes", "legendFormat": "DB Size {{pod}}", "refId": "A" }], "title": "etcd DB Size", "type": "timeseries" },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }, "id": 40, "title": "API Server", "type": "row" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity", "showPoints": "never" }, "unit": "reqps" } }, "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 }, "id": 41, "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } }, "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (verb) (rate(apiserver_request_total[5m]))", "legendFormat": "{{verb}}", "refId": "A" }], "title": "API Server — Request Rate (by verb)", "type": "timeseries" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity", "showPoints": "never" }, "unit": "reqps" } }, "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 }, "id": 42, "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } }, "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (code) (rate(apiserver_request_total{code=~\"5..\"}[5m]))", "legendFormat": "HTTP {{code}}", "refId": "A" }], "title": "API Server — Error Rate (5xx)", "type": "timeseries" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity", "showPoints": "never" }, "unit": "s" } }, "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 }, "id": 43, "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } }, "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, sum by (le, verb) (rate(apiserver_request_duration_seconds_bucket{verb!~\"WATCH|CONNECT\"}[5m])))", "legendFormat": "P99 {{verb}}", "refId": "A" }], "title": "API Server — Latency P99 (bez WATCH)", "type": "timeseries" },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 }, "id": 50, "title": "MachineConfigPool", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "custom": { "align": "left", "displayMode": "auto", "filterable": false, "minWidth": 100 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "name" }, "properties": [ { "id": "displayName", "value": "Pool" }, { "id": "custom.width", "value": 180 } ] },
          { "matcher": { "id": "byName", "options": "Total" }, "properties": [ { "id": "custom.width", "value": 80 } ] },
          { "matcher": { "id": "byName", "options": "Updated" }, "properties": [ { "id": "custom.width", "value": 90 }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "yellow", "value": null }, { "color": "green", "value": 1 } ] } } ] },
          { "matcher": { "id": "byName", "options": "Degraded" }, "properties": [ { "id": "custom.width", "value": 90 }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } ] },
          { "matcher": { "id": "byName", "options": "Unavailable" }, "properties": [ { "id": "custom.width", "value": 100 }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 46 },
      "id": 51,
      "options": { "footer": { "show": false }, "showHeader": true },
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["name", "Value #A", "Value #B", "Value #C", "Value #D"] } } },
        { "id": "organize", "options": { "renameByName": { "Value #A": "Total", "Value #B": "Updated", "Value #C": "Degraded", "Value #D": "Unavailable" } } }
      ],
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "machine_config_pool_machine_count", "instant": true, "refId": "A", "format": "table" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "machine_config_pool_updated_machine_count", "instant": true, "refId": "B", "format": "table" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "machine_config_pool_degraded_machine_count", "instant": true, "refId": "C", "format": "table" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "machine_config_pool_unavailable_machine_count", "instant": true, "refId": "D", "format": "table" }
      ],
      "title": "MachineConfigPool Status",
      "type": "table"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 }, "id": 60, "title": "Firing Alerts", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "custom": { "align": "left", "displayMode": "auto", "filterable": true, "minWidth": 120 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "alertname" }, "properties": [ { "id": "displayName", "value": "Alert" }, { "id": "custom.width", "value": 260 } ] },
          { "matcher": { "id": "byName", "options": "namespace" }, "properties": [ { "id": "custom.width", "value": 160 } ] },
          { "matcher": { "id": "byName", "options": "severity" }, "properties": [ { "id": "custom.width", "value": 100 }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "mappings", "value": [ { "type": "value", "options": { "critical": { "text": "CRITICAL", "color": "red", "index": 0 } } }, { "type": "value", "options": { "warning": { "text": "WARNING", "color": "orange", "index": 1 } } }, { "type": "value", "options": { "info": { "text": "INFO", "color": "blue", "index": 2 } } } ] } ] }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 55 },
      "id": 61,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "displayName": "severity", "desc": true }] },
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["alertname", "namespace", "severity", "job"] } } }
      ],
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "ALERTS{alertstate=\"firing\"}", "instant": true, "refId": "A", "format": "table" }
      ],
      "title": "Aktywne Alerty (firing)",
      "type": "table"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 65 }, "id": 70, "title": "Pod Restarts", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "custom": { "align": "left", "displayMode": "auto", "filterable": true, "minWidth": 120 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "namespace" }, "properties": [ { "id": "custom.width", "value": 160 } ] },
          { "matcher": { "id": "byName", "options": "pod" }, "properties": [ { "id": "custom.width", "value": 280 } ] },
          { "matcher": { "id": "byName", "options": "container" }, "properties": [ { "id": "custom.width", "value": 160 } ] },
          { "matcher": { "id": "byName", "options": "Restarty (1h)" }, "properties": [ { "id": "custom.width", "value": 120 }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 10 } ] } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 66 },
      "id": 71,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "displayName": "Restarty (1h)", "desc": true }] },
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["namespace", "pod", "container", "Value"] } } },
        { "id": "organize", "options": { "renameByName": { "Value": "Restarty (1h)" } } }
      ],
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "topk(15, sum by (namespace, pod, container) (increase(kube_pod_container_status_restarts_total[1h])) > 0)", "instant": true, "refId": "A", "format": "table" }
      ],
      "title": "Top Pod Restarts (ostatnia godzina)",
      "type": "table"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 74 }, "id": 80, "title": "PersistentVolumes", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity", "showPoints": "never" }, "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 } ] } }
      },
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 75 },
      "id": 81,
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "100 * kubelet_volume_stats_used_bytes / kubelet_volume_stats_capacity_bytes", "legendFormat": "{{namespace}}/{{persistentvolumeclaim}}", "refId": "A" }
      ],
      "title": "PV Usage (%)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "custom": { "align": "left", "displayMode": "auto", "filterable": true, "minWidth": 100 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "namespace" }, "properties": [ { "id": "custom.width", "value": 140 } ] },
          { "matcher": { "id": "byName", "options": "persistentvolumeclaim" }, "properties": [ { "id": "displayName", "value": "PVC" }, { "id": "custom.width", "value": 200 } ] },
          { "matcher": { "id": "byName", "options": "Used %" }, "properties": [ { "id": "custom.width", "value": 90 }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "unit", "value": "percent" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 } ] } } ] },
          { "matcher": { "id": "byName", "options": "Available" }, "properties": [ { "id": "unit", "value": "bytes" }, { "id": "custom.width", "value": 100 } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 75 },
      "id": 82,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "displayName": "Used %", "desc": true }] },
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["namespace", "persistentvolumeclaim", "Value #A", "Value #B"] } } },
        { "id": "organize", "options": { "renameByName": { "Value #A": "Used %", "Value #B": "Available" } } }
      ],
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "100 * kubelet_volume_stats_used_bytes / kubelet_volume_stats_capacity_bytes", "instant": true, "refId": "A", "format": "table" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kubelet_volume_stats_available_bytes", "instant": true, "refId": "B", "format": "table" }
      ],
      "title": "PV Details",
      "type": "table"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 83 }, "id": 90, "title": "Certyfikaty", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 30 }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 180 } ] }, "unit": "d", "noValue": "N/A" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 84 },
      "id": 91,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "min(kubelet_certificate_manager_server_ttl_seconds) / 86400", "legendFormat": "Kubelet Server Cert", "instant": true, "refId": "A" }
      ],
      "title": "Kubelet Cert TTL (dni)",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity", "showPoints": "never" }, "unit": "d", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 30 }, { "color": "red", "value": 7 } ] } }
      },
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 84 },
      "id": 92,
      "options": { "tooltip": { "mode": "multi", "sort": "asc" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kubelet_certificate_manager_server_ttl_seconds / 86400", "legendFormat": "Kubelet {{node}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "min(apiserver_client_certificate_expiration_seconds_bucket{le!=\"0\"}) / 86400", "legendFormat": "API Client Certs (min)", "refId": "B" }
      ],
      "title": "Certyfikaty — dni do wygasniecia",
      "type": "timeseries"
    }

  ]
}
